    function test_RegistryMarkSeasonEndedSacrifice() public {
        vm.prank(owner);
        registry.markSeasonEnded(1, alice, true, 10 ether, 5 ether);

        (address winner, bool wasSacrifice, , uint256 seed) = registry.seasonOutcome(1);
        assertEq(winner,       alice,   "Winner should be alice");
        assertEq(wasSacrifice, true,    "Should be sacrifice");
        assertEq(seed,         5 ether, "Seed amount recorded");
    }

    function test_RegistryCannotEndUnlaunchedSeason() public {
        // Register a second season but don't launch it
        vm.startPrank(owner);
        BlockHuntTreasury   treasury2   = new BlockHuntTreasury(creator);
        BlockHuntToken      token2      = new BlockHuntToken("uri", creator, 1000, address(mockVRFCoordinator));
        BlockHuntMintWindow mintWindow2 = new BlockHuntMintWindow();
        BlockHuntForge      forge2      = new BlockHuntForge(address(mockVRFCoordinator));

        registry.registerSeason(2, address(treasury2), address(token2), address(mintWindow2), address(forge2));

        vm.expectRevert("Not launched");
        registry.markSeasonEnded(2, alice, false, 0, 0);
        vm.stopPrank();
    }

    function test_RegistryCannotEndSeasonTwice() public {
        vm.startPrank(owner);
        registry.markSeasonEnded(1, alice, false, 10 ether, 0);

        vm.expectRevert("Already ended");
        registry.markSeasonEnded(1, alice, false, 10 ether, 0);
        vm.stopPrank();
    }

    function test_RegistryGetAuthorisedSeedDestination() public {
        // Register Season 2 so there's a valid next season
        vm.startPrank(owner);
        BlockHuntTreasury   treasury2   = new BlockHuntTreasury(creator);
        BlockHuntToken      token2      = new BlockHuntToken("uri", creator, 1000, address(mockVRFCoordinator));
        BlockHuntMintWindow mintWindow2 = new BlockHuntMintWindow();
        BlockHuntForge      forge2      = new BlockHuntForge(address(mockVRFCoordinator));

        registry.registerSeason(2, address(treasury2), address(token2), address(mintWindow2), address(forge2));
        registry.markSeasonEnded(1, alice, true, 10 ether, 5 ether); // sacrifice
        vm.stopPrank();

        address dest = registry.getAuthorisedSeedDestination(1);
        assertEq(dest, address(treasury2), "Seed destination should be Season 2 treasury");
    }

    function test_RegistryGetAuthorisedSeedDestinationFailsIfNotSacrifice() public {
        vm.startPrank(owner);
        BlockHuntTreasury   treasury2   = new BlockHuntTreasury(creator);
        BlockHuntToken      token2      = new BlockHuntToken("uri", creator, 1000, address(mockVRFCoordinator));
        BlockHuntMintWindow mintWindow2 = new BlockHuntMintWindow();
        BlockHuntForge      forge2      = new BlockHuntForge(address(mockVRFCoordinator));

        registry.registerSeason(2, address(treasury2), address(token2), address(mintWindow2), address(forge2));
        registry.markSeasonEnded(1, alice, false, 10 ether, 0); // claim, not sacrifice
        vm.stopPrank();

        vm.expectRevert("Not a sacrifice");
        registry.getAuthorisedSeedDestination(1);
    }

    function test_RegistryGetNextSeasonTreasury() public {
        vm.startPrank(owner);
        BlockHuntTreasury   treasury2   = new BlockHuntTreasury(creator);
        BlockHuntToken      token2      = new BlockHuntToken("uri", creator, 1000, address(mockVRFCoordinator));
        BlockHuntMintWindow mintWindow2 = new BlockHuntMintWindow();
        BlockHuntForge      forge2      = new BlockHuntForge(address(mockVRFCoordinator));

        registry.registerSeason(2, address(treasury2), address(token2), address(mintWindow2), address(forge2));
        vm.stopPrank();

        address next = registry.getNextSeasonTreasury(1);
        assertEq(next, address(treasury2), "Should return Season 2 treasury");
    }

    function test_RegistryGetNextSeasonTreasuryFailsIfNotRegistered() public view {
        // Season 2 not registered
        assertEq(registry.totalSeasons(), 1, "Only Season 1 registered");
    }

    function test_RegistryOnlyOwnerCanRegister() public {
        vm.prank(alice);
        vm.expectRevert();
        registry.registerSeason(2, address(treasury), address(token), address(mintWindow), address(forge));
    }

    function test_RegistryOnlyOwnerCanMarkLaunched() public {
        vm.prank(alice);
        vm.expectRevert();
        registry.markSeasonLaunched(1);
    }

    function test_RegistryOnlyOwnerCanMarkEnded() public {
        vm.prank(alice);
        vm.expectRevert();
        registry.markSeasonEnded(1, alice, false, 0, 0);
    }

    function test_RegistryLogSeedTransfer() public {
        // Register Season 2 first
        vm.startPrank(owner);
        BlockHuntTreasury   treasury2   = new BlockHuntTreasury(creator);
        BlockHuntToken      token2      = new BlockHuntToken("uri", creator, 1000, address(mockVRFCoordinator));
        BlockHuntMintWindow mintWindow2 = new BlockHuntMintWindow();
        BlockHuntForge      forge2      = new BlockHuntForge(address(mockVRFCoordinator));
        registry.registerSeason(2, address(treasury2), address(token2), address(mintWindow2), address(forge2));
        vm.stopPrank();

        // logSeedTransfer can only be called by the from-season treasury
        vm.prank(address(treasury));
        registry.logSeedTransfer(1, 2, 5 ether); // should emit event without reverting
    }

    function test_RegistryLogSeedTransferFailsIfNotTreasury() public {
        vm.startPrank(owner);
        BlockHuntTreasury   treasury2   = new BlockHuntTreasury(creator);
        BlockHuntToken      token2      = new BlockHuntToken("uri", creator, 1000, address(mockVRFCoordinator));
        BlockHuntMintWindow mintWindow2 = new BlockHuntMintWindow();
        BlockHuntForge      forge2      = new BlockHuntForge(address(mockVRFCoordinator));
        registry.registerSeason(2, address(treasury2), address(token2), address(mintWindow2), address(forge2));
        vm.stopPrank();

        vm.prank(alice);
        vm.expectRevert("Only from-season treasury");
        registry.logSeedTransfer(1, 2, 5 ether);
    }


    // ═════════════════════════════════════════════════════════════════════════
    // 11. INTEGRATION / END-TO-END TESTS
    // ═════════════════════════════════════════════════════════════════════════

    function test_FullGameFlow_Claim() public {
        // 1. Mint blocks
        vm.prank(alice);
        token.mint{value: MINT_PRICE * 50}(50);

        // 2. Give alice all 6 tiers (simulate grinding) - also triggers countdown
        for (uint256 tier = 2; tier <= 7; tier++) {
            _giveBlocks(alice, tier, 1);
        }

        // 3. Countdown triggers on both Token and Countdown contracts
        assertEq(token.countdownActive(), true);
        assertEq(countdown.isActive(),    true);

        // 4. Others can vote
        vm.prank(bob);
        countdown.castVote(false);  // vote claim

        // 5. Wait 7 days, then Alice claims
        vm.deal(address(treasury), 5 ether);
        uint256 aliceBefore = alice.balance;

        vm.warp(block.timestamp + 7 days + 1);
        vm.prank(alice);
        token.claimTreasury();

        assertGt(alice.balance, aliceBefore,         "Alice should have received ETH");
        assertEq(token.countdownActive(), false,      "Game should end");
        assertEq(countdown.isActive(),    false,      "Countdown contract should sync");
    }

    function test_FullGameFlow_Sacrifice_ThenMigration() public {
        // 1. Give alice all tiers and sacrifice
        for (uint256 tier = 2; tier <= 7; tier++) {
            _giveBlocks(alice, tier, 1);
        }

        vm.deal(address(treasury), 10 ether);

        vm.warp(block.timestamp + 7 days + 1);
        vm.prank(alice);
        token.sacrifice(new address[](0), new uint256[](0));

        // 2. Alice holds The Origin
        assertEq(token.balanceOf(alice, 1), 1);

        // 3. Countdown holds the 40% community pool; 10% already went to season2Seed
        assertApproxEqAbs(countdown.communityPool(), 4 ether, 0.001 ether, "40% held in countdown");
        assertApproxEqAbs(season2Seed.balance,       1 ether, 0.001 ether, "10% sent to season2Seed");

        // 4. Migration window opens for Season 1 → Season 2
        _giveBlocks(bob, 7, 500);

        vm.prank(owner);
        migration.openMigrationWindow();

        vm.prank(bob);
        migration.migrate();

        assertEq(migration.hasMigrated(bob),    true, "Bob migrated to Season 2");
        assertEq(migration.migrationReward(bob), 150, "Bob gets 150 starters");
    }

    function test_MultiplePlayersCannotTriggerSimultaneousCountdowns() public {
        // Alice triggers countdown
        for (uint256 tier = 2; tier <= 7; tier++) {
            _giveBlocks(alice, tier, 1);
        }
        assertEq(token.countdownActive(), true);
        assertEq(token.countdownHolder(), alice);

        // Bob also collects all tiers - countdown should NOT reassign
        for (uint256 tier = 2; tier <= 7; tier++) {
            _giveBlocks(bob, tier, 1);
        }

        // Holder should still be alice
        assertEq(token.countdownHolder(), alice, "First holder keeps countdown");
    }

    function test_FullGameFlow_VRFForge_ThenWin() public withVRFEnabled {
        // Alice forges using VRF and then wins the game

        // 1. Give alice Tier-7 blocks and forge toward Tier-6 (T7 ratio=20, burn all = 100%)
        _giveBlocks(alice, 7, 20);

        vm.prank(alice);
        forge.forge(7, 20);  // requestId = 1 - (20*100)/20 = 100% success

        // Chainlink delivers: randomWord = 0 → 0 % 100 = 0 < 100 → success
        mockVRFCoordinator.fulfillRequest(1, 0);
        assertEq(token.balanceOf(alice, 6), 1, "Alice forged a Tier-6 via VRF");

        // 2. Give alice the rest of the tiers and trigger countdown
        for (uint256 tier = 2; tier <= 5; tier++) {
            _giveBlocks(alice, tier, 1);
        }
        _giveBlocks(alice, 7, 1);  // Tier 7 needed for complete set
        assertEq(token.countdownActive(), true, "Countdown should trigger");

        // 3. Wait and claim
        vm.deal(address(treasury), 5 ether);
        vm.warp(block.timestamp + 7 days + 1);
        vm.prank(alice);
        token.claimTreasury();

        assertFalse(token.countdownActive(), "Game should be over");
    }


    // ═════════════════════════════════════════════════════════════════════════
    // 3d. FORGE - NEW PROBABILITY ANCHORING TESTS
    //
    // Forge success is now: (blocksBurned * 100) / combineRatioForTier
    // T7→T6: ratio 20. T6→T5: ratio 20. T5→T4: ratio 30. T4→T3: ratio 30. T3→T2: ratio 50.
    // Burning the full ratio = 100% (same outcome as combine, but combine is guaranteed).
    // ═════════════════════════════════════════════════════════════════════════

    function test_ForgeT7_HalfRatioIs50Percent() public withVRFEnabled {
        // T7 ratio=20. Burn 10 → (10*100)/20 = 50% success.
        _giveBlocks(alice, 7, 10);
        vm.prank(alice);
        forge.forge(7, 10);  // requestId = 1
        // randomWord=49 → 49%100=49 < 50 → success
        mockVRFCoordinator.fulfillRequest(1, 49);
        assertEq(token.balanceOf(alice, 6), 1, "Burn 10 of 20 = 50% - should succeed at 49");
    }

    function test_ForgeT5_HalfRatioIs50Percent() public withVRFEnabled {
        // T5 ratio=30. Burn 15 → (15*100)/30 = 50% success.
        _giveBlocks(alice, 5, 15);
        vm.prank(alice);
        forge.forge(5, 15);
        // randomWord=49 → 49 < 50 → success
        mockVRFCoordinator.fulfillRequest(1, 49);
        assertEq(token.balanceOf(alice, 4), 1, "Burn 15 of 30 = 50% - should succeed at 49");
    }

    function test_ForgeT3_HalfRatioIs50Percent() public withVRFEnabled {
        // T3 ratio=50. Burn 25 → (25*100)/50 = 50% success.
        _giveBlocks(alice, 3, 25);
        vm.prank(alice);
        forge.forge(3, 25);
        mockVRFCoordinator.fulfillRequest(1, 49);
        assertEq(token.balanceOf(alice, 2), 1, "Burn 25 of 50 = 50% - should succeed at 49");
    }

    function test_ForgeFullRatioIs100Percent() public withVRFEnabled {
        // Burning the full combine ratio = (ratio*100)/ratio = 100%.
        // randomWord % 100 is always 0–99, always < 100 → guaranteed success.
        _giveBlocks(alice, 7, 20);
        vm.prank(alice);
        forge.forge(7, 20);
        mockVRFCoordinator.fulfillRequest(1, 99);  // worst random still succeeds
        assertEq(token.balanceOf(alice, 6), 1, "Burning full ratio should always succeed");
    }

    function test_ForgeExceedsRatioReverts() public {
        _giveBlocks(alice, 7, 21);
        vm.prank(alice);
        vm.expectRevert("Burn amount must be 1 to combine ratio for this tier");
        forge.forge(7, 21);  // T7 ratio=20, 21 exceeds it
    }

    function test_ForgeZeroReverts() public {
        _giveBlocks(alice, 7, 5);
        vm.prank(alice);
        vm.expectRevert("Burn amount must be 1 to combine ratio for this tier");
        forge.forge(7, 0);  // minimum is 1
    }

    function test_ForgeTier2IsInvalid() public {
        _giveBlocks(alice, 2, 10);
        vm.prank(alice);
        vm.expectRevert("Invalid tier");
        forge.forge(2, 10);  // T2→T1 forge is not possible - sacrifice-only path
    }

    function test_ForgeT4_QuarterRatioIs25Percent() public withVRFEnabled {
        // T4 ratio=30. Burn 8 → (8*100)/30 = 26% (integer division: 26).
        // randomWord=25 → 25 < 26 → success. randomWord=26 → 26 >= 26 → fail.
        _giveBlocks(alice, 4, 8);
        vm.prank(alice);
        forge.forge(4, 8);
        mockVRFCoordinator.fulfillRequest(1, 26);  // 26 >= 26 → fail
        assertEq(token.balanceOf(alice, 3), 0, "Should fail when random = successChance");
    }


    // ═════════════════════════════════════════════════════════════════════════
    // 7d. ENDGAME - SACRIFICE DISTRIBUTION TESTS
    //
    // Tests the full sacrifice distribution flow:
    //   50% -> winner | 40% -> entitlement claim pool | 10% -> season2Seed
    // Players call claimLeaderboardReward() with no arguments - entitlements
    // are written to storage at sacrifice time and read directly.
    // ═════════════════════════════════════════════════════════════════════════

    /// @dev Helper: builds player/amount arrays for a single leaderboard entrant.
    function _singleEntitlement(address player, uint256 amount)
        internal pure returns (address[] memory players, uint256[] memory amounts)
    {
        players = new address[](1);
        amounts  = new uint256[](1);
        players[0] = player;
        amounts[0]  = amount;
    }

    /// @dev Helper: sets up sacrifice state on countdown for direct unit tests.
    ///      Alice triggers countdown, 7 days pass, then sacrifice is executed.
    function _doSacrifice(uint256 treasuryAmount, address[] memory players, uint256[] memory amounts) internal {
        vm.deal(address(treasury), treasuryAmount);
        _giveAllTiers(alice);
        vm.warp(block.timestamp + 7 days + 1);
        vm.prank(alice);
        token.sacrifice(players, amounts);
    }

    function test_Sacrifice_EntitlementStoredOnCountdown() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);
        assertEq(countdown.leaderboardEntitlement(bob), 4 ether, "Bob entitlement should be stored");
    }

    function test_Sacrifice_ClaimWindowSet() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);
        assertGt(countdown.claimWindowExpiry(), block.timestamp, "Claim window should be in future");
    }

    function test_ClaimLeaderboardReward_Valid() public {
        uint256 bobShare = 4 ether; // 40% of 10 ether
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, bobShare);
        _doSacrifice(10 ether, players, amounts);

        uint256 bobBefore = bob.balance;
        vm.prank(bob);
        countdown.claimLeaderboardReward();

        assertEq(bob.balance - bobBefore, bobShare, "Bob should receive his full entitlement");
        assertEq(countdown.hasClaimed(bob), true,   "Bob should be marked as claimed");
        assertEq(countdown.communityPool(), 0,       "Pool should be empty after full claim");
    }

    function test_ClaimLeaderboardReward_NoEntitlement_Reverts() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);

        // Carol has no entitlement - should be rejected
        vm.prank(carol);
        vm.expectRevert("No entitlement");
        countdown.claimLeaderboardReward();
    }

    function test_ClaimLeaderboardReward_DoubleClaim_Reverts() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);

        vm.prank(bob);
        countdown.claimLeaderboardReward();

        vm.prank(bob);
        vm.expectRevert("Already claimed");
        countdown.claimLeaderboardReward();
    }

    function test_ClaimLeaderboardReward_AfterExpiry_Reverts() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);

        // Fast-forward past the 30-day claim window
        vm.warp(block.timestamp + 31 days);

        vm.prank(bob);
        vm.expectRevert("Claim window has expired");
        countdown.claimLeaderboardReward();
    }

    function test_ClaimLeaderboardReward_MultipleEntrants() public {
        // Bob gets 2 ether, carol gets 1 ether (3 ether of the 4 ether pool, 1 stays as dust)
        address[] memory players = new address[](2);
        uint256[] memory amounts  = new uint256[](2);
        players[0] = bob;   amounts[0] = 2 ether;
        players[1] = carol; amounts[1] = 1 ether;
        _doSacrifice(10 ether, players, amounts);

        uint256 bobBefore   = bob.balance;
        uint256 carolBefore = carol.balance;

        vm.prank(bob);
        countdown.claimLeaderboardReward();

        vm.prank(carol);
        countdown.claimLeaderboardReward();

        assertEq(bob.balance   - bobBefore,   2 ether, "Bob gets his 2 ether");
        assertEq(carol.balance - carolBefore, 1 ether, "Carol gets her 1 ether");
        assertEq(countdown.communityPool(),   1 ether, "1 ether dust remains unclaimed");
    }

    function test_SweepUnclaimedRewards_AfterExpiry() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);

        uint256 season2SeedBefore = season2Seed.balance;

        // Bob never claims - sweep after 30 days
        vm.warp(block.timestamp + 31 days);
        countdown.sweepUnclaimedRewards();  // permissionless - anyone can call

        assertEq(countdown.communityPool(), 0,                     "Pool should be emptied");
        assertEq(season2Seed.balance - season2SeedBefore, 4 ether, "Unclaimed funds swept to season2Seed");
    }

    function test_SweepUnclaimedRewards_BeforeExpiry_Reverts() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);

        // Only 15 days have passed - claim window still open
        vm.warp(block.timestamp + 15 days);
        vm.expectRevert("Claim window still open");
        countdown.sweepUnclaimedRewards();
    }

    function test_SweepUnclaimedRewards_IsPermissionless() public {
        (address[] memory players, uint256[] memory amounts) = _singleEntitlement(bob, 4 ether);
        _doSacrifice(10 ether, players, amounts);

        vm.warp(block.timestamp + 31 days);

        // Carol (random non-owner) can trigger the sweep - Gelato keeper pattern
        vm.prank(carol);
        countdown.sweepUnclaimedRewards();

        assertEq(countdown.communityPool(), 0, "Carol should be able to trigger sweep");
    }

    function test_SweepWithNoSacrifice_Reverts() public {
        vm.expectRevert("No sacrifice has occurred");
        countdown.sweepUnclaimedRewards();
    }

    function test_Sacrifice_NoSeason2SeedAddress_Reverts() public {
        // Deploy a fresh countdown with no season2SeedAddress set
        vm.startPrank(owner);
        BlockHuntCountdown freshCountdown = new BlockHuntCountdown();
        freshCountdown.setTokenContract(address(token));
        // deliberately do NOT call setSeason2SeedAddress
        vm.stopPrank();

        assertEq(freshCountdown.season2SeedAddress(), address(0), "Should be unset");
    }

    function test_Sacrifice_EntitlementsExceedPool_Reverts() public {
        // Entitlements that sum to more than the 40% pool should revert
        vm.deal(address(treasury), 10 ether);  // pool = 4 ether
        _giveAllTiers(alice);
        vm.warp(block.timestamp + 7 days + 1);

        address[] memory players = new address[](1);
        uint256[] memory amounts  = new uint256[](1);
        players[0] = bob;
        amounts[0]  = 5 ether;  // exceeds the 4 ether pool

        vm.prank(alice);
        vm.expectRevert("Entitlements exceed community pool");
        token.sacrifice(players, amounts);
    }


    // ═════════════════════════════════════════════════════════════════════════
    // 3e. MINT VRF - GAS SCALING TEST
    // ═════════════════════════════════════════════════════════════════════════

    function test_MintVRF_GasLimitScalesWithQuantity() public withMintVRFEnabled {
        // Verify that large mint VRF callbacks are delivered without reverting.
        // A 200-block mint previously failed with the fixed 200k gas limit.
        // The aggregation optimisation reduces mintBatch to ≤6 entries regardless of quantity.

        // Give alice enough ETH for 200 mints
        vm.prank(alice);
        token.mint{value: MINT_PRICE * 200}(200);

        // Simulate Chainlink delivering the callback - must not revert due to gas
        mockVRFCoordinator.fulfillRequest(1, 99999);

        uint256 total = 0;
        for (uint256 tier = 1; tier <= 7; tier++) {
            total += token.balanceOf(alice, tier);
        }
        assertEq(total, 200, "All 200 blocks should be delivered via large mint callback");
    }

    function test_MintVRF_TierAggregationProducesCorrectTotal() public withMintVRFEnabled {
        // Regardless of how tiers are distributed, total block count must equal minted quantity
        vm.prank(alice);
        token.mint{value: MINT_PRICE * 50}(50);

        mockVRFCoordinator.fulfillRequest(1, 42);

        uint256 total = 0;
        for (uint256 tier = 2; tier <= 7; tier++) {
            total += token.balanceOf(alice, tier);
        }
        assertEq(total, 50, "Aggregated tier mint must sum to exactly 50");
    }

    /// @dev Modifier: enables VRF on the token contract (mint path)
    modifier withMintAndForgeVRFEnabled() {
        vm.startPrank(owner);
        token.setVrfConfig(1, bytes32(uint256(1)), 500_000);
        token.setVrfEnabled(true);
        forge.setVrfConfig(1, bytes32(uint256(0x9e1344a1247c8a1785d0a4681a27152bffdb43666ae5bf7d14d24a5efd44bf71)), 200_000);
        forge.setVrfEnabled(true);
        vm.stopPrank();
        _;
    }

    // ─────────────────────────────────────────────────────────────────────────

    /// @dev Mints blocks directly to a player via testMint - bypasses window.
    function _giveBlocks(address player, uint256 tier, uint256 amount) internal {
        vm.prank(owner);
        token.mintForTest(player, tier, amount);
    }

    /// @dev Give a player exactly one block of every tier (2–7), triggering countdown.
    function _giveAllTiers(address player) internal {
        vm.startPrank(owner);
        for (uint256 tier = 2; tier <= 7; tier++) {
            token.mintForTest(player, tier, 1);
        }
        vm.stopPrank();
    }
}
